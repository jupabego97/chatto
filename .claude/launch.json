{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "chatto",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "CHATTO_WEBSERVER_PORT=${PORT:-4000} CHATTO_WEBSERVER_URL=http://localhost:${PORT:-4000} exec mise chatto run"],
      "port": 4000,
      "autoPort": true,
      "env": {
        "CHATTO_NATS_EMBEDDED_PORT": "0",
        "CHATTO_BOOTSTRAP_LOGIN": "hmans",
        "CHATTO_BOOTSTRAP_EMAIL": "hendrik@mans.de",
        "CHATTO_BOOTSTRAP_PASSWORD": "devpassword",
        "CHATTO_BOOTSTRAP_SPACE_NAME": "Chatto",
        "CHATTO_SMTP_HOST": "mailpit.k8s.orb.local",
        "CHATTO_SMTP_PORT": "1025",
        "CHATTO_LIVEKIT_ENABLED": "true",
        "CHATTO_LIVEKIT_URL": "ws://livekit.chatto-tools.orb.local:7880",
        "CHATTO_LIVEKIT_API_KEY": "devkey",
        "CHATTO_LIVEKIT_API_SECRET": "secret"
      }
    }
  ]
}
