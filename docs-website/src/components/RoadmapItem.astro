---
interface Props {
  title: string;
  status: 'done' | 'in-progress' | 'planned' | 'not-planned';
}

const labels: Record<Props['status'], string> = {
  'done': 'Shipped',
  'in-progress': 'In Progress',
  'planned': 'Planned',
  'not-planned': 'Not Planned',
};

const { title, status } = Astro.props;
const label = labels[status];
---

<div class:list={['roadmap-item', status]}>
  <div class="roadmap-header">
    <span class="roadmap-title">{title}</span>
    <span class:list={['roadmap-badge', status]}>{label}</span>
  </div>
  <div class="roadmap-body">
    <slot />
  </div>
</div>

<style>
  .roadmap-item {
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-left: 3px solid var(--sl-color-gray-4);
    border-radius: 0.5rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .roadmap-item.done {
    border-left-color: var(--sl-color-green-high);
  }

  .roadmap-item.in-progress {
    border-left-color: var(--sl-color-orange-high);
  }

  .roadmap-item.planned {
    border-left-color: var(--sl-color-purple-high);
  }

  .roadmap-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .roadmap-title {
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .roadmap-badge {
    font-size: var(--sl-text-xs);
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .roadmap-badge.done {
    background: var(--sl-color-green-low);
    color: var(--sl-color-green-high);
  }

  .roadmap-badge.in-progress {
    background: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
  }

  .roadmap-badge.planned {
    background: var(--sl-color-purple-low);
    color: var(--sl-color-purple-high);
  }

  .roadmap-badge.not-planned {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
  }

  .roadmap-body {
    margin-top: 0.35rem;
    color: var(--sl-color-gray-3);
  }
</style>
