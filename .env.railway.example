# Copia estos valores a Variables en Railway (no subas secretos reales al repo).
# Genera secretos hex de 32 bytes, por ejemplo en PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })

# --- Obligatorio ---
RAILWAY_RUN_UID=0
PORT=8080

# Tras Generate Domain:
CHATTO_WEBSERVER_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

# Email del primer admin (owner al verificarse por web; también úsalo en operator create)
CHATTO_OWNERS_EMAILS=tu@email.com

# Secretos (64 caracteres hex cada uno; cámbialos)
CHATTO_WEBSERVER_COOKIE_SIGNING_SECRET=4d38cee568f1a2b3922ecbcbfaa27c631d06eb4b9261f977167101d27b49987f
CHATTO_WEBSERVER_COOKIE_ENCRYPTION_SECRET=65c3a42f8186adc76e21f900c974c10921f3f42f14b367232f000b887d89cff0
CHATTO_CORE_SECRET_KEY=21d3b4e1d9ed9d7660c71da66d08408b1f88bc4fe4e7794c3c5aa6cba4b2abf5
CHATTO_CORE_ASSETS_SIGNING_SECRET=c35c70b54efe758560a5ca1fa872bb5cb89c7814c82c1fe8e50196921d1cc4a2

# Operator API (crear admin sin SMTP vía railway ssh / shell)
CHATTO_OPERATOR_API_ENABLED=true
CHATTO_OPERATOR_API_SOCKET_PATH=/tmp/chatto/operator.sock

# --- Opción A: sin email (recomendado al principio) ---
CHATTO_SMTP_ENABLED=false

# --- Opción B: registro por web con Resend ---
# 1) Crea cuenta en https://resend.com
# 2) API Keys → Create API Key
# 3) (Opcional) verifica un dominio; si no, usa onboarding@resend.dev solo para pruebas
# CHATTO_SMTP_ENABLED=true
# CHATTO_SMTP_HOST=smtp.resend.com
# CHATTO_SMTP_PORT=465
# CHATTO_SMTP_TLS=implicit
# CHATTO_SMTP_USERNAME=resend
# CHATTO_SMTP_PASSWORD=re_xxxxxxxxxxxxxxxx
# CHATTO_SMTP_FROM=onboarding@resend.dev

# --- Opción C: Gmail (App Password) ---
# CHATTO_SMTP_ENABLED=true
# CHATTO_SMTP_HOST=smtp.gmail.com
# CHATTO_SMTP_PORT=587
# CHATTO_SMTP_TLS=mandatory
# CHATTO_SMTP_USERNAME=tu@gmail.com
# CHATTO_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# CHATTO_SMTP_FROM=tu@gmail.com

# --- Opcional ---
# CHATTO_AUTH_DIRECT_REGISTRATION=false
# CHATTO_VIDEO_ENABLED=true
