# Copia estos valores a Variables en Railway (no subas secretos reales al repo).
# Genera secretos hex de 32 bytes, por ejemplo en PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })

# --- Obligatorio en Railway ---
RAILWAY_RUN_UID=0

# URL pública (Railway la rellena tras Generate Domain):
# CHATTO_WEBSERVER_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
CHATTO_WEBSERVER_URL=https://TU-SERVICIO.up.railway.app

# Emails que serán owners al verificarse (usa el email del primer registro)
CHATTO_OWNERS_EMAILS=tu@email.com

# Secretos (cámbialos; no reutilices estos ejemplos)
CHATTO_WEBSERVER_COOKIE_SIGNING_SECRET=4d38cee568f1a2b3922ecbcbfaa27c631d06eb4b9261f977167101d27b49987f
CHATTO_WEBSERVER_COOKIE_ENCRYPTION_SECRET=65c3a42f8186adc76e21f900c974c10921f3f42f14b367232f000b887d89cff0
CHATTO_CORE_SECRET_KEY=21d3b4e1d9ed9d7660c71da66d08408b1f88bc4fe4e7794c3c5aa6cba4b2abf5
CHATTO_CORE_ASSETS_SIGNING_SECRET=c35c70b54efe758560a5ca1fa872bb5cb89c7814c82c1fe8e50196921d1cc4a2

# --- SMTP (necesario para registro email/password, verificación y reset) ---
CHATTO_SMTP_ENABLED=true
CHATTO_SMTP_HOST=smtp.example.com
CHATTO_SMTP_PORT=587
CHATTO_SMTP_TLS=mandatory
CHATTO_SMTP_USERNAME=
CHATTO_SMTP_PASSWORD=
CHATTO_SMTP_FROM=noreply@example.com

# --- Ya aplicados por el Dockerfile / entrypoint (opcionales) ---
# CHATTO_NATS_EMBEDDED_ENABLED=true
# CHATTO_NATS_EMBEDDED_DATA_DIR=/data
# CHATTO_LIVEKIT_ENABLED=false
# CHATTO_LOG_LEVEL=info
# CHATTO_LOG_FORMAT=json

# --- Opcional: desactivar registro público tras el primer owner ---
# CHATTO_AUTH_DIRECT_REGISTRATION=false

# --- Opcional: push (npx web-push generate-vapid-keys) ---
# CHATTO_PUSH_ENABLED=true
# CHATTO_PUSH_VAPID_PUBLIC_KEY=
# CHATTO_PUSH_VAPID_PRIVATE_KEY=
# CHATTO_PUSH_VAPID_SUBJECT=mailto:tu@email.com

# --- Opcional: video transcoding (ffmpeg ya viene en la imagen) ---
# CHATTO_VIDEO_ENABLED=true
